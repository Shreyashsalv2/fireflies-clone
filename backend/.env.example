# Copy to .env and fill in. NEVER commit the real .env.

# Groq API key — get one free at https://console.groq.com
# Leave blank to run fully offline (summaries use a deterministic mock fallback).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Comma is not used; single production frontend origin (the Vercel URL).
FRONTEND_URL=http://localhost:3000

# SQLite by default; override for Postgres in production if desired.
DATABASE_URL=sqlite:///./fireflies.db
